<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filtres thématiques"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Active des catégories entières. Appliqué immédiatement. Les catégories « médias » reflètent des classements éditoriaux (donc subjectifs) et restent modifiables dans les fichiers de l'app."
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp" />

    <ListView
        android:id="@+id/themes_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
