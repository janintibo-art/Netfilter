<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/brand_navy</item>
        <item name="android:colorPrimaryDark">@color/brand_navy</item>
        <item name="android:colorAccent">@color/brand_teal</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:buttonStyle">@style/AppButton</item>
    </style>

    <!-- Bouton par défaut : arrondi, discret, appliqué à toute l'app -->
    <style name="AppButton" parent="@android:style/Widget.Material.Button.Borderless">
        <item name="android:background">@drawable/btn_secondary</item>
        <item name="android:textColor">@color/brand_navy</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:minHeight">50dp</item>
        <item name="android:paddingLeft">18dp</item>
        <item name="android:paddingRight">18dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>
